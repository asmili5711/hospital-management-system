<div class="admin-profile-container">
  <div class="profile-header">
    <div>
      <h1 class="page-title">Admin Profile</h1>
      <p class="page-subtitle">View your account details and update your password.</p>
    </div>
    <a href="<%= returnTo %>" class="back-btn">
      <i class="fa-solid fa-arrow-left"></i>
      Back
    </a>
  </div>

  <% if (feedback) { %>
    <div class="feedback-banner <%= feedback.type === 'success' ? 'feedback-success' : 'feedback-error' %>">
      <%= feedback.message %>
    </div>
  <% } %>

  <div class="profile-grid">
    <section class="profile-card">
      <h2 class="section-title">Account Details</h2>

      <div class="detail-list">
        <div class="detail-item">
          <span class="detail-label">Email</span>
          <span class="detail-value"><%= admin.email %></span>
        </div>

        <div class="detail-item">
          <span class="detail-label">Role</span>
          <span class="detail-value"><%= admin.role %></span>
        </div>

        <div class="detail-item">
          <span class="detail-label">Created Date</span>
          <span class="detail-value"><%= admin.createdAt ? new Date(admin.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %></span>
        </div>
      </div>
    </section>

    <section class="profile-card">
      <h2 class="section-title">Password Settings</h2>

      <details class="password-panel" <%= feedback ? 'open' : '' %>>
        <summary class="toggle-password-btn">Change Password</summary>

        <form method="POST" action="/admin/profile/change-password" class="password-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="returnTo" value="<%= returnTo %>">

          <label class="field-group" for="currentPassword">
            <span class="field-label">Current Password</span>
            <input id="currentPassword" name="currentPassword" type="password" required minlength="6">
          </label>

          <label class="field-group" for="newPassword">
            <span class="field-label">New Password</span>
            <input id="newPassword" name="newPassword" type="password" required minlength="6">
          </label>

          <label class="field-group" for="confirmPassword">
            <span class="field-label">Confirm New Password</span>
            <input id="confirmPassword" name="confirmPassword" type="password" required minlength="6">
          </label>

          <button type="submit" class="update-password-btn">Update Password</button>
        </form>
      </details>
    </section>
  </div>
</div>
