<div class="form-card">

  <h3 class="form-heading text-center mb-4">
    <%= isEdit ? 'Edit Doctor Details' : 'Doctor Details' %>
  </h3>

  <% if (feedback) { %>
    <div class="alert alert-<%= feedback.type === 'error' ? 'danger' : 'success' %>" role="alert">
      <%= feedback.message %>
    </div>
  <% } %>

  <% const doctorFormAction = `${formAction || '/admin/doctors'}?_csrf=${encodeURIComponent(csrfToken)}`; %>
  <form method="POST" action="<%= doctorFormAction %>" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <!-- Doctor Name -->
    <div class="mb-3">
      <label class="form-label">Doctor Name</label>
      <input type="text" name="name" class="form-control" placeholder="Enter doctor name" value="<%= doctor ? doctor.name : '' %>" required>
    </div>

    <!-- Doctor Department -->
    <div class="mb-3">
      <label class="form-label">Department</label>
      <% const departments = ['Cardiology', 'Orthopedics', 'Neurology', 'Pediatrics', 'General Surgery', 'Dermatology', 'General Medicine', 'ENT', 'Ophthalmology', 'Gynecology']; %>
      <select name="department" class="form-control" required>
        <option value="" <%= !(doctor && doctor.department) ? 'selected' : '' %> disabled>Select department</option>
        <% departments.forEach((dept) => { %>
          <option value="<%= dept %>" <%= doctor && doctor.department === dept ? 'selected' : '' %>><%= dept %></option>
        <% }) %>
      </select>
    </div>

    <!-- Age -->
    <div class="mb-3">
      <label class="form-label">Age</label>
      <input type="number" name="age" class="form-control" placeholder="Enter age" min="0" value="<%= doctor ? doctor.age : '' %>" required>
    </div>

    <!-- Experience -->
    <div class="mb-3">
      <label class="form-label">Experience (Years)</label>
      <input type="number" name="experience" class="form-control" placeholder="Enter years of experience" min="0" value="<%= doctor ? doctor.experience : 0 %>">
    </div>

    <!-- Image File Upload -->
    <div class="mb-3">
      <label class="form-label">Upload Image</label>
      <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.avif">
      <small class="text-muted">Upload a JPG, PNG, WEBP, or AVIF image up to 5 MB.</small>
    </div>

    <!-- Description -->
    <div class="mb-3">
      <label class="form-label">Description</label>
      <textarea name="description" class="form-control" rows="3" placeholder="Enter description" required><%= doctor ? doctor.description : '' %></textarea>
    </div>

    <!-- Buttons -->
    <div class="d-flex justify-content-between">
      <button type="submit" class="btn btn-primary">
        <%= submitLabel || 'Submit' %>
      </button>

      <a href="/admin/doctors_management">
        <button type="button" class="btn btn-secondary">
          Cancel
        </button>
      </a>
    </div>
  </form>

</div>
