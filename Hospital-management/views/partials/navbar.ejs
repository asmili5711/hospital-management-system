<%
  const profileReturnTo =
    activePage === 'users' ? '/admin/user_management' :
    activePage === 'doctors' ? '/admin/doctors_management' :
    activePage === 'reports' ? '/admin/reports' :
    activePage === 'logout' ? '/admin/logout' :
    activePage === 'profile' ? '/admin/profile' :
    '/admin/appoinment';
%>
<nav class="admin-nav">
  <a href="/admin/appoinment" class="brand-logo" aria-label="Medicare Admin Home">
    <span class="brand-logo-icon">
      <i class="fa-solid fa-heart-pulse" aria-hidden="true"></i>
    </span>
    <span class="brand-logo-text">Medicare</span>
  </a>

  <div class="nav-links">
    <a href="/admin/appoinment" class="<%= activePage === 'appointments' ? 'active' : '' %>">
      Appointments
    </a>

    <a href="/admin/doctors_management" class="<%= activePage === 'doctors' ? 'active' : '' %>">
      Doctors Management
    </a>

    <a href="/admin/user_management" class="<%= activePage === 'users' ? 'active' : '' %>">
      User Management
    </a>

    <a href="/admin/reports" class="<%= activePage === 'reports' ? 'active' : '' %>">
      Reports
    </a>
  </div>

  <details class="nav-menu">
    <summary
      class="menu-trigger <%= activePage === 'logout' ? 'active' : '' %>"
      title="Open menu"
      aria-label="Open menu"
    >
      <i class="fa-solid fa-bars-staggered" aria-hidden="true"></i>
    </summary>

    <div class="menu-dropdown">
      <a href="/admin/profile?returnTo=<%= encodeURIComponent(profileReturnTo) %>" class="menu-item profile-item">Profile</a>
      <a href="/admin/logout" class="menu-item logout-item">Logout</a>
    </div>
  </details>
</nav>
