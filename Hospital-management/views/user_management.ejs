<div class="users-container">
  <h1 class="page-title">User Management</h1>

  <div class="table-wrapper">
    <table class="users-table">
      <thead>
        <tr>
          <th>S.No</th>
          <th>User Name</th>
          <th>Block</th>
          <th>Unblock</th>
          <th>Appointment History</th>
        </tr>
      </thead>

      <tbody>
        <% if (users && users.length) { %>
          <% users.forEach((user, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= user.name %></td>
              <td>
                <form method="POST" action="/admin/users/<%= user.id %>/block">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn block-btn" type="submit" <%= user.isBlocked ? 'disabled' : '' %>>
                    Block
                  </button>
                </form>
              </td>
              <td>
                <form method="POST" action="/admin/users/<%= user.id %>/unblock">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn unblock-btn" type="submit" <%= user.isBlocked ? '' : 'disabled' %>>
                    Unblock
                  </button>
                </form>
              </td>
              <td>
                <a href="/admin/users/<%= user.id %>/bookings" class="history-btn">
                  View (<%= user.appointmentCount %>)
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5">No users found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
